# EasyRecon — copy to .env and fill in your Groq key (free at https://console.groq.com)

# Groq (intent + scope + fast Roman Urdu answers)
GROQ_API_KEY=gsk_your_key_here
GROQ_INTENT_MODEL=llama-3.3-70b-versatile
INTENT_PROVIDER=groq
EXPLAIN_PROVIDER=groq

# Ollama (local SQL generation — answers use Groq when EXPLAIN_PROVIDER=groq)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b
# Optional faster MoE model for SQL only: ollama pull qwen3.5:35b-a3b
# OLLAMA_SQL_MODEL=qwen3.5:35b-a3b
OLLAMA_KEEP_ALIVE=30m

# Skip 2nd LLM for simple tabular/scalar results (instant Roman Urdu)
FAST_ANSWERS=true

# API server
API_HOST=127.0.0.1
API_PORT=8000

# Speech — Azure ur-PK (Pakistan standard). Setup: docs/AZURE_SPEECH_SETUP.md
SPEECH_STT_PROVIDER=azure
SPEECH_TTS_PROVIDER=azure
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_LANGUAGE=ur-PK
TTS_VOICE=ur-PK-UzmaNeural
SPEECH_FALLBACK=true
LOCAL_WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
STT_LANGUAGE=ur
# Groq Whisper STT: SPEECH_STT_PROVIDER=groq

# Twilio WhatsApp (https://console.twilio.com — free sandbox for demo)
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_PHARMACY_NAME=Bismillah Medical Store
